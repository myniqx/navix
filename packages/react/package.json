{
  "name": "@navix/react",
  "version": "0.1.0",
  "description": "Spatial navigation library for web-based TV platforms (Tizen, WebOS, browser)",
  "author": "myniqx",
  "license": "MIT",
  "keywords": ["tv", "navigation", "focus", "spatial", "react", "tizen", "webos", "remote-control"],
  "repository": {
    "type": "git",
    "url": "https://github.com/myniqx/navix.git",
    "directory": "packages/react"
  },
  "homepage": "https://github.com/myniqx/navix/tree/main/packages/react#readme",
  "bugs": {
    "url": "https://github.com/myniqx/navix/issues"
  },
  "private": false,
  "type": "module",
  "files": ["dist", "README.md"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
