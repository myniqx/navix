{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 80,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "trailingComma": "all",
  "ignorePatterns": ["dist/", "build/", "*.tsbuildinfo", "coverage/"],
  "sortImports": {
    "enabled": true
  }
}
